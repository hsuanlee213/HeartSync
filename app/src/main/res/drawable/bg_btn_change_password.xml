<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow shadow: cyan 50% alpha, offset down -->
    <item
        android:top="4dp"
        android:bottom="-4dp"
        android:left="2dp"
        android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#8000FFFF" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <!-- Main gradient: Cyan to #00AAAA -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00FFFF"
                android:endColor="#FF00AAAA"
                android:angle="0" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>
