        <item name="boxBackgroundColor">@color/tech_input_bg</item>
        <item name="boxStrokeColor">@color/tech_stroke_color</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/tech_label_gray</item>
