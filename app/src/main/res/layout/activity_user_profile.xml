<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UserProfileActivity"
    android:id="@+id/user_profile"
    android:paddingBottom="16dp">

    <!-- Top Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_profile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="Edit Profile"
        app:titleTextColor="@android:color/white"
        android:background="?attr/colorPrimary"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar_profile"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Username (Read-only) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="Username">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:focusable="false"
                    android:clickable="false"
                    android:textStyle="bold"
                    tools:text="test_user123" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email (Read-only) - This ID resolves the previous error -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Email">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:focusable="false"
                    android:clickable="false"
                    android:textStyle="bold"
                    tools:text="user@example.com" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Reminder Message (Cannot be changed) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Note: Username and Email are fixed for your account security and cannot be changed after registration."
                android:textColor="@color/design_default_color_error"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"/>

            <!-- Change Password Button -->
            <Button
                android:id="@+id/btn_change_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Change Password"
                android:layout_marginBottom="16dp"/>

            <!-- Link to History Analysis -->
            <Button
                android:id="@+id/btn_analyze_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Analyze My History"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="16dp"/>

            <!-- Logout Button -->
            <Button
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Logout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/design_default_color_error"
                android:layout_marginTop="32dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>