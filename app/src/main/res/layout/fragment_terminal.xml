<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/deep_purple"
    tools:context=".terminal.TerminalFragment">

    <!-- Geometric heart (Compose) -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/heart_animation_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Mode switcher (ZEN / SYNC / OVERDRIVE) — Terminal tab only -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/mode_switcher_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="?attr/colorSurface"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@+id/btn_mode_sync">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mode_zen"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:checkable="true"
            android:text="ZEN"
            android:textAllCaps="true" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mode_sync"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:checkable="true"
            android:text="SYNC"
            android:textAllCaps="true" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mode_overdrive"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checkable="true"
            android:text="OVERDRIVE"
            android:textAllCaps="true" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

</LinearLayout>
