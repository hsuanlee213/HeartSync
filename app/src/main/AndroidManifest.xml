<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Required for streaming audio from the network during testing -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required for Android 11+ to see Google Play Services (Firebase Auth, etc.) -->
    <queries>
        <package android:name="com.google.android.gms" />
    </queries>

    <application
        android:name=".HeartBeatMusicApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HeartBeatMusic">

        <!-- Yuchen - LoginActivity as the ONLY launcher -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>


        <activity
            android:name=".UserProfileActivity"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar" />

        <activity
            android:name=".AnalyzeHistoryActivity"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar" />

        <!-- MainActivity - NO launcher intent-filter, only declared ONCE -->
        <activity
            android:name=".MainActivity"
            android:exported="false"/>

        <!-- Yuchen - Login system activities -->
        <activity
            android:name=".LoginFormActivity"
            android:exported="false"/>

        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan"/>

        <!-- Other existing activities -->
        <activity
            android:name=".ModeAdapter"
            android:exported="false" />

        <activity
            android:name=".MusicLibraryActivity"
            android:exported="false" />

    </application>

</manifest>