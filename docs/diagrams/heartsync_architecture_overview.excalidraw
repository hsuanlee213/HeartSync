    {
      "id": "principles-text",
      "type": "text",
      "x": 60,
      "y": 88,
      "width": 760,
      "height": 55,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
